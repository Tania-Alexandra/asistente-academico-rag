{
  "name": "Python 3.11 - RAG Project",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "onCreateCommand": "python3 -m venv .venv",
  "updateContentCommand": "source .venv/bin/activate && pip install -r requirements.txt",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python"
      }
    }
  }
}

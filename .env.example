# Variables de entorno para el Asistente Académico RAG
# Copia este archivo como .env y reemplaza con tus claves reales

# Clave para GitHub Models / Azure OpenAI
GITHUB_TOKEN=ghp_tu_token_aqui

# URL base para el endpoint de inferencia (Azure / GitHub Models)
# Deja vacío si usas OpenAI oficial con OPENAI_API_KEY.
GITHUB_BASE_URL=https://models.inference.ai.azure.com

# Si usas OpenAI directo también puedes definirlo
OPENAI_API_KEY=sk-tu_token_openai_aqui

# Nota: el proyecto usará GITHUB_TOKEN si está presente, sino OPENAI_API_KEY.
# load_dotenv() está configurado para sobrescribir variables de entorno existentes con
# los valores definidos en este archivo, lo que facilita usar .env localmente.